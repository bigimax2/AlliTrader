# Django Configuration
SECRET_KEY=<сгенерируйте_секретный_ключ_через_scripts/generate_secret_key.py>

# Debug mode (False для продакшена)
DEBUG=False

# Allowed hosts (через запятую)
ALLOWED_HOSTS=localhost,127.0.0.1,your-server.com

# Webhook Secret Token (для auto-deploy системы)
WEBHOOK_SECRET_TOKEN=<сгенерируйте_токен_через_scripts/generate_webhook_token.py>

# CSRF Trusted Origins (через запятую)
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,https://your-server.com

# Database (MySQL)
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=127.0.0.1
DB_PORT=3306

# Redis (для Celery брокера)
CELERY_BROKER_UR=redis://127.0.0.1:6379/4

# Redis (для кэша Celery)
CELERY_CACHE_DB=redis://127.0.0.1:6379/5

# Project Name (для многопроектной установки)
PROJECT_NAME=Main

# Redis префикс для изоляции задач между несколькими проектами на одном сервере
CELERY_KEY_PREFIX=Main_celery

# Django Settings Module
DJANGO_SETTINGS_MODULE=Main.settings

# ESI Configuration (EVE Online SSO)
ESI_SSO_CLIENT_ID=<ваш_esi_client_id>
ESI_SSO_CLIENT_SECRET=<ваш_esi_secret_key>
ESI_SSO_CALLBACK_URL=https://your-server.com/sso/callback

# Use Celery (True/False)
USE_CELERY=True

# Enable Trader application (True/False)
ENABLE_TRADER=True

# SDE API Configuration
SDE_API_URL=https://api.niceplatform.ru/
SDE_API_KEY=<ваш_sde_api_key>

# Discord Configuration (опционально, если используется)
ENABLE_DISCORD=False
DISCORD_APPLICATION_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=
DISCORD_GUILD_ID=
DISCORD_BOT_TOKEN=

