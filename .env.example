# Django Configuration
SECRET_KEY=<сгенерируйте_секретный_ключ_через_scripts/generate_secret_key.py>

# Debug mode (False для продакшена)
DEBUG=False

# Allowed hosts (через запятую)
ALLOWED_HOSTS=localhost,127.0.0.1,your-server.com

# Webhook Secret Token (для auto-deploy системы)
WEBHOOK_SECRET_TOKEN=<сгенерируйте_токен_через_scripts/generate_webhook_token.py>

# Database (MySQL)
DATABASE_URL=mysql://user:password@localhost:3306/dbname

# Redis (для Celery брокера)
REDIS_URL=redis://localhost:6379/0

# Project Name (для многопроектной установки)
PROJECT_NAME=Main

# Django Settings Module
DJANGO_SETTINGS_MODULE=Main.settings

# ESI Configuration (EVE Online)
ESI_CLIENT_ID=<ваш_esi_client_id>
ESI_SECRET_KEY=<ваш_esi_secret_key>
ESI_CALLBACK_URL=http://localhost:8000/sso/callback/

# Discord Configuration (если используется)
DISCORD_BOT_TOKEN=<ваш_discord_bot_token>

# Email Configuration (опционально)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=<ваш_email@gmail.com>
EMAIL_HOST_PASSWORD=<пароль_от_email>
EMAIL_USE_TLS=True
