SECRET_KEY=your-secret-key-here
DEBUG=True

# Database
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306

# Eve Online SSO
ESI_SSO_CLIENT_ID=your_esi_client_id
ESI_SSO_CLIENT_SECRET=your_esi_client_secret
ESI_SSO_CALLBACK_URL=http://127.0.0.1:8000/sso/callback/

# Discord
ENABLE_DISCORD=True
ENABLE_DISCORD_SYNC=True
DISCORD_APPLICATION_ID=your_discord_app_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://127.0.0.1:8000/discord/oauth/callback/
DISCORD_API_ENDPOINT=https://discord.com/api
DISCORD_GUILD_ID=your_guild_id
DISCORD_BOT_TOKEN=your_discord_bot_token

# Redis (Celery)
CELERY_BROKER_URL=redis://127.0.0.1:6379/4